# Для сканирования рынков ключ Polymarket не нужен — публичный Gamma API.

# --- Telegram ---
# Токен бота. Без него dry-run: сигналы только в консоль.
TELEGRAM_TOKEN=

# ID чата или канала, куда слать сообщения.
CHAT_ID=

# --- Режим работы ---
# 1 — не слать в Telegram, сигналы в консоль.
# 0 — слать в Telegram, если заданы TELEGRAM_TOKEN и CHAT_ID.
DRY_RUN=1

# Что запускать: bot | run_tests | test_message .
MODE=bot

# --- Сеть и цикл опроса ---
# Таймаут HTTP-запросов к Polymarket и Telegram, секунд.
REQUEST_TIMEOUT=20

# Пауза между полными проходами сканирования, секунд.
POLL_INTERVAL_SECONDS=60

# Сколько циклов выполнить: 0 = бесконечно; 1 = один проход и выход.
MAX_LOOPS=0

# --- Polymarket Gamma API Docs ---
# Базовый URL списка ивентов; менять только если Polymarket даст другой endpoint.
GAMMA_EVENTS_URL=https://gamma-api.polymarket.com/events

# Поле сортировки списка ивентов (query order). На стороне API: volume24hr, liquidity, start_date и т.д.
# Не использовать volume_24hr с подчёркиванием — сейчас даёт 422 validation error.
GAMMA_EVENTS_ORDER=volume24hr

# Сколько ивентов запрашивать за один запрос (пагинация, макс. порция).
MAX_EVENTS_PER_REQUEST=100

# true — только активные ивенты (параметр active=true у API).
ONLY_ACTIVE=true

# true — только не закрытые ивенты (в API closed=false).
ONLY_OPEN=true

# --- Отбор ивентов по ликвидности и объёму (фильтр до анализа рынков) ---
# Минимальный объём ивента за 24 часа ($), ниже — ивент пропускается.
MIN_EVENT_VOLUME_24H=1000

# Минимальная ликвидность ивента ($), ниже — пропуск.
MIN_EVENT_LIQUIDITY=5000

# --- Логи в консоль ---
# Уровень: DEBUG / INFO.
LOG_LEVEL=INFO

# --- Прокси (опционально) ---
# По умолчанию запросы к Polymarket идут без прокси, к Telegram — только если задать TELEGRAM_* ниже.
# Вариант А — одной строкой (логин/пароль в URL; спецсимволы в пароле лучше кодировать %XX или вариант Б):
# TELEGRAM_PROXY_URL=http://user:password@192.0.2.1:8080
# Для SOCKS5: socks5://user:password@192.0.2.1:1080 (нужен пакет PySocks в requirements)
#
# Вариант Б — хост, порт, логин, пароль отдельно (удобно если в пароле есть @ : # и т.д.):
# TELEGRAM_PROXY_HOST=192.0.2.1
# TELEGRAM_PROXY_PORT=8080
# TELEGRAM_PROXY_USER=myuser
# TELEGRAM_PROXY_PASSWORD=mypass
#
# Если Polymarket тоже нужен через прокси (редко):
# GAMMA_PROXY_URL=...
# или GAMMA_PROXY_HOST / GAMMA_PROXY_PORT / GAMMA_PROXY_USER / GAMMA_PROXY_PASSWORD
#
# --- botv3.py: RSS / Google News (если ленты недоступны без прокси) ---
# Те же поля с префиксом NEWS_ (URL или HOST/PORT/USER/PASSWORD).
# NEWS_PROXY_URL=...
#
# --- botv3.py: опционально (есть дефолты в коде) ---
# NEWS_MAX_AGE_MINUTES=15
# NEWS_LOOKBACK_MINUTES=30
# TOP_NEWS_PER_CYCLE=25
# MIN_NEWS_STRENGTH=2
# HISTORY_LOOKBACK_MINUTES=15
# CLOB_BOOK_API=https://clob.polymarket.com/book
# CLOB_HISTORY_API=https://clob.polymarket.com/prices-history
# MIN_ABSOLUTE_MISMATCH=0.08
# MIN_EXPECTED_MOVE=0.06
# MAX_MOVE_ALREADY_REACTED=0.07
#
# --- TheNewsAPI (для botv5.py, api.thenewsapi.com) ---
# Ключ: https://www.thenewsapi.com/ — в логи ключ не попадает.
# THENEWSAPI_API_KEY=
# ENABLE_THENEWSAPI=1
# THENEWSAPI_LIMIT=3
# THENEWSAPI_DOMAINS=reuters.com,bloomberg.com,cnbc.com,coindesk.com,theblock.co
# Запросы search — многострочно или через |||, как NEWSAPI_QUERIES:
# THENEWSAPI_QUERIES=SEC ETF approval
# Раз в N циклов бота (счётчик run_bot); после 429 — пауза THENEWSAPI_BACKOFF_MINUTES.
# THENEWSAPI_EVERY_N_CYCLES=2
# THENEWSAPI_BACKOFF_MINUTES=15
#
# --- NewsAPI (для botv5.py, newsapi.org /v2/everything) ---
# По умолчанию в коде ENABLE_NEWSAPI=0. Включить: ENABLE_NEWSAPI=1 и ключ.
# Без ключа отключите источник: ENABLE_NEWSAPI=0 или не задавайте ключ.
# NEWSAPI_API_KEY=
# Базовый URL (редко меняют):
# NEWSAPI_BASE_URL=https://newsapi.org/v2/everything
# Список запросов q — по одному на строку или через ||| в одной строке (переопределяет дефолты в коде):
# NEWSAPI_QUERIES=(SEC OR regulator) AND (ETF OR bitcoin)
# NEWSAPI_QUERIES=|||(Federal Reserve OR Fed) AND rates
# Домены через запятую (не смешивать с NEWSAPI_SOURCES — в API только один вариант):
# NEWSAPI_DOMAINS=reuters.com,bloomberg.com,cnbc.com
# Только Reuters: NEWSAPI_ONLY_REUTERS=1
# Или вместо domains — id источников NewsAPI:
# NEWSAPI_SOURCES=bloomberg,reuters
# Нижняя граница времени публикации (ISO 8601). Пусто = автоматически от NEWS_LOOKBACK_MINUTES:
# NEWSAPI_FROM=2026-04-01T00:00:00Z
# Верхняя граница (опционально):
# NEWSAPI_TO=2026-04-05T23:59:59Z
# NEWSAPI_LANGUAGE=en
# NEWSAPI_SORT_BY=publishedAt
# NEWSAPI_SEARCH_IN=title,description
# NEWSAPI_PAGE_SIZE=25
#
# --- botv5.py: прочее ---
# DB_PATH=polymarket_bot_v5.sqlite3
# MODE=bot
# ENABLE_GOOGLE_RSS=1
# ENABLE_NEWSAPI=0
# ENABLE_THENEWSAPI=1
# ENABLE_GDELT=1
# GDELT_QUERIES_ENV=  (многострочно; иначе два коротких дефолтных запроса в коде)
# Пауза между запросами к GDELT; при 429 — повтор, затем GDELT_BACKOFF_MINUTES без запросов
# GDELT_INTER_REQUEST_DELAY=6
# GDELT_429_RETRY_DELAY=30
# GDELT_BACKOFF_MINUTES=30
# GDELT_MAX_RECORDS=10
# Каждые N циклов run_bot (аналог GDELT_EVERY_N_CYCLES): GDELT_FETCH_EVERY_N_CYCLES=5
# При частых 429: ENABLE_GDELT=0
