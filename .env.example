# Скопируйте в файл .env и заполните значения. Файл .env в git не коммитить.
# Для сканирования рынков ключ Polymarket не нужен — публичный Gamma API.

# --- Telegram (бот @BotFather) ---
# Токен бота. Без него и без CHAT_ID сигналы только в консоль (dry-run).
TELEGRAM_TOKEN=

# ID чата или канала, куда слать сообщения (число или @channelusername для каналов с username).
CHAT_ID=

# --- Режим работы ---
# 1 / true / yes — не слать в Telegram, печатать сигналы в консоль (удобно для проверки).
# 0 — слать в Telegram, если заданы TELEGRAM_TOKEN и CHAT_ID.
DRY_RUN=0

# Что запускать: bot (основной цикл) | run_tests (юнит-тесты) | test_message (одно тестовое сообщение в Telegram).
MODE=bot

# --- Сеть и цикл опроса ---
# Таймаут HTTP-запросов к Polymarket и Telegram, секунд.
REQUEST_TIMEOUT=20

# Пауза между полными проходами сканирования, секунд.
POLL_INTERVAL_SECONDS=60

# Сколько циклов выполнить: 0 = бесконечно; 1 = один проход и выход (удобно для отладки).
MAX_LOOPS=0

# --- Polymarket Gamma API (документация: developers/gamma-markets-api, endpoint /events) ---
# Базовый URL списка ивентов; менять только если Polymarket даст другой endpoint.
GAMMA_EVENTS_URL=https://gamma-api.polymarket.com/events

# Сколько ивентов запрашивать за один запрос (пагинация, макс. порция).
MAX_EVENTS_PER_REQUEST=100

# true — только активные ивенты (параметр active=true у API).
ONLY_ACTIVE=true

# true — только не закрытые ивенты (в API передаётся closed=false).
ONLY_OPEN=true

# --- Отбор ивентов по ликвидности и объёму (фильтр до анализа рынков) ---
# Минимальный объём ивента за 24 часа ($), ниже — ивент пропускается.
MIN_EVENT_VOLUME_24H=1000

# Минимальная ликвидность ивента ($), ниже — пропуск.
MIN_EVENT_LIQUIDITY=5000

# --- Логи в консоль ---
# Уровень: DEBUG (подробнее) или INFO (обычный).
LOG_LEVEL=INFO
